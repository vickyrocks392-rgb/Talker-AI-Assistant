# ── Server ───────────────────────────────────────────────────────────
# The port the backend listens on  (default: 3000)
PORT=3000

# Environment: "development" or "production"  (default: development)
NODE_ENV=development

# ── Ollama (Local LLM) ───────────────────────────────────────────────
# URL of the Ollama server  (default: http://127.0.0.1:11434)
OLLAMA_URL=http://127.0.0.1:11434

# Ollama model name to use for chat / summarization
# Supported: llama3.1:8b, llama3.2:3b, qwen3:4b, gemma3  (default: llama3.2:3b)
OLLAMA_MODEL=llama3.2:3b

# ── Vite Dev Server (development only) ───────────────────────────────
# Override the Vite HMR websocket port (only needed when the default
# HMR port conflicts with another service on your machine).
# HMR_PORT=24679

# Set to "true" to disable HMR in constrained runtimes (Docker, Cloud Run).
# DISABLE_HMR=true

